<section class="page-block">
  <h2>{{ p.page.name }}</h2>
  <p><a href="{{ p.page.url }}">{{ p.page.url }}</a> · {{ p.page.timestamp }}</p>
  {% if p.page.error %}
    <p class="error">Error: {{ p.page.error }}</p>
  {% endif %}
  <div class="screenshot-wrap" style="position:relative; display:inline-block; max-width:100%;">
    {% if p.page.screenshot %}
      <img class="page-screenshot" src="screenshots/{{ p.page.screenshot | basename }}" alt="{{ p.page.name }} screenshot" style="display:block; max-width:100%; height:auto;" />
      <div class="overlay-layer" style="position:absolute; inset:0; pointer-events:none; transform-origin:top left;">
      {% for f in p.findings %}
        {% set item = p.page.texts | selectattr("selector", "equalto", f.selector) | list | first %}
        {% if item %}
          <div class="overlay-box" title="{{ f.text }} (detected {{ f.detected }})"
               style="position:absolute; left:{{ item.bbox.x }}px; top:{{ item.bbox.y }}px; width:{{ item.bbox.w }}px; height:{{ item.bbox.h }}px; outline:2px solid red; pointer-events:auto;"></div>
        {% endif %}
      {% endfor %}
      </div>
    {% else %}
      <p><em>No screenshot captured.</em></p>
    {% endif %}
  </div>
  <table class="findings">
    <thead><tr><th>Text</th><th>Detected</th><th>Expected</th><th>Confidence</th><th>Selector</th></tr></thead>
    <tbody>
      {% for f in p.findings %}
        <tr>
          <td>{{ f.text }}</td>
          <td>{{ f.detected }}</td>
          <td>{{ f.expected }}</td>
          <td>{{ "%.2f" | format(f.confidence) }}</td>
          <td><code>{{ f.selector }}</code></td>
        </tr>
      {% else %}
        <tr><td colspan="5"><em>No findings.</em></td></tr>
      {% endfor %}
    </tbody>
  </table>
  {% if p.gemini_review %}
    <div class="gemini-review">
      <h3>Gemini native-quality review
        <span class="gemini-score gemini-score-{{ p.gemini_review.quality_score }}">
          {{ p.gemini_review.quality_score }}/5
        </span>
        <small>({{ p.gemini_review.model }})</small>
      </h3>
      <p><strong>Summary:</strong> {{ p.gemini_review.quality_summary }}</p>
      <p><strong>English on page:</strong>
        {% if p.gemini_review.english_present %}
          <span class="tag tag-warn">yes</span>
        {% else %}
          <span class="tag tag-ok">no</span>
        {% endif %}
      </p>
      {% if p.gemini_review.english_examples %}
        <p><strong>English examples:</strong></p>
        <ul>
          {% for ex in p.gemini_review.english_examples %}
            <li><code>{{ ex }}</code></li>
          {% endfor %}
        </ul>
      {% endif %}
      {% if p.gemini_review.format_issues %}
        <p><strong>Format-convention issues:</strong></p>
        <ul>
          {% for iss in p.gemini_review.format_issues %}
            <li>{{ iss }}</li>
          {% endfor %}
        </ul>
      {% else %}
        <p><strong>Format-convention issues:</strong> <em>none flagged</em></p>
      {% endif %}
    </div>
  {% endif %}
</section>
