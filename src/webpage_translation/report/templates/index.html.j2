<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>Traveloka Locale QA — {{ payload.meta.locale }}</title>
<style>
  body { font-family: system-ui, sans-serif; margin: 2rem; }
  h1 { margin-bottom: 0.25rem; }
  section.page-block { margin-bottom: 3rem; border-top: 1px solid #ccc; padding-top: 1rem; }
  img.page-screenshot { max-width: 100%; height: auto; border: 1px solid #ddd; }
  table.findings { border-collapse: collapse; margin-top: 1rem; width: 100%; }
  table.findings th, table.findings td { border: 1px solid #ccc; padding: 0.4rem 0.6rem; text-align: left; }
  .error { color: #b00020; font-weight: bold; }
  .gemini-review { margin-top: 1rem; padding: 0.8rem 1rem; background: #f6f8fa; border-left: 4px solid #6b73ff; border-radius: 4px; }
  .gemini-review h3 { margin-top: 0; }
  .gemini-score { display: inline-block; padding: 0.1rem 0.5rem; margin-left: 0.4rem; border-radius: 999px; font-size: 0.9rem; font-weight: 600; color: white; }
  .gemini-score-1, .gemini-score-2 { background: #b00020; }
  .gemini-score-3 { background: #b8860b; }
  .gemini-score-4 { background: #2e7d32; }
  .gemini-score-5 { background: #1b5e20; }
  .tag { display: inline-block; padding: 0.1rem 0.5rem; border-radius: 4px; font-size: 0.9rem; font-weight: 600; }
  .tag-ok { background: #d5f5df; color: #1b5e20; }
  .tag-warn { background: #ffe1e1; color: #b00020; }
</style>
</head>
<body>
<h1>Traveloka Locale QA</h1>
<p>Locale: <strong>{{ payload.meta.locale }}</strong> · Date: {{ payload.meta.date }} · Generated: {{ payload.meta.generated_at }}</p>
{% for p in payload.pages %}
  {% include "page.html.j2" %}
{% endfor %}
<script>
function syncOverlays() {
  document.querySelectorAll(".screenshot-wrap").forEach(wrap => {
    const img = wrap.querySelector("img.page-screenshot");
    const layer = wrap.querySelector(".overlay-layer");
    if (!img || !layer || !img.naturalWidth) return;
    const scale = img.clientWidth / img.naturalWidth;
    layer.style.width = img.naturalWidth + "px";
    layer.style.height = img.naturalHeight + "px";
    layer.style.transform = "scale(" + scale + ")";
  });
}
window.addEventListener("load", syncOverlays);
window.addEventListener("resize", syncOverlays);
document.querySelectorAll("img.page-screenshot").forEach(img => {
  if (img.complete) syncOverlays();
  else img.addEventListener("load", syncOverlays);
});
</script>
</body>
</html>
